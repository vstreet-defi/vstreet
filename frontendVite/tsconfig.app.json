{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "allowJs": true,

    /* Linting */
    "strict": true,
    "noFallthroughCasesInSwitch": true,

    // custom
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "components/*": ["./src/vstreet/components/*"],
      "contexts/*": ["./src/vstreet/contexts/*"],
      "hooks/*": ["./src/vstreet/hooks/*"],
      "services/*": ["./src/vstreet/services/*"],
      "types/*": ["./src/vstreet/types/*"],
      "utils/*": ["./src/vstreet/utils/*"],
      "smart-contracts-tools": ["./src/vstreet/smart-contracts-tools/index.ts"],
      "smart-contracts-tools/*": ["./src/vstreet/smart-contracts-tools/*"],
      "utils": ["./src/vstreet/utils/index.ts"],
      "consts": ["./src/vstreet/consts.ts"]
    }
  },
  "include": ["src"]
}
